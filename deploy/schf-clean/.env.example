# ==================================================
# SCHF Clean - Environment Configuration
# ==================================================
# Copy this file to .env and fill in your values.
# Never commit .env to version control.

# --- Instance ---
SCHF_INSTANCE_ID=change-me
SCHF_INSTANCE_NAME=My SCHF Instance
SCHF_ENVIRONMENT=production
SCHF_PUBLIC_URL=http://localhost:8084

# --- Port ---
SCHF_PORT=8084

# --- Database ---
POSTGRES_DB=schf_v2
POSTGRES_USER=schf
SCHF_DATABASE_PASSWORD=CHANGE_ME_GENERATE_A_STRONG_PASSWORD

# --- Redis ---
SCHF_REDIS_PASSWORD=CHANGE_ME_GENERATE_ANOTHER_STRONG_PASSWORD

# --- JWT ---
SCHF_JWT_SECRET=CHANGE_ME_GENERATE_A_64_CHAR_PLUS_SECRET

# --- CORS (comma-separated) ---
SCHF_ALLOWED_ORIGINS=http://localhost:8084

# --- Backup ---
SCHF_BACKUP_DIRECTORY=D:\SCHF\_runtime\schf-clean\backups
